@page "/pick/qlearn"

@inject NavigationManager _navigationManager


<div class="container mt-5">
    <div class="d-flex align-items-center justify-content-center mb-5">
        <div class="me-3">
            <span class="back-btn" @onclick="GoBack"><i class="fa-solid fa-arrow-left"></i></span>
        </div>
        <div class="text-center">
            <h1 class="display-4 fw-bold mb-0">RL Bot</h1>
            <p class="lead text-muted mt-2">Select the Reinforcement Learning training</p>
        </div>
    </div>

    <div class="bot-selection-grid text-center">
        <div class="bot-card" @onclick="PlayUntrained">
            <i class="fa-solid fa-battery-empty fa-3x mb-3 text-danger"></i>
            <h5>Untrained</h5>
            <span class="bot-desc">Clueless and random</span>
        </div>
        <div class="bot-card" @onclick="PlayPartial">
            <i class="fa-solid fa-battery-half fa-3x mb-3 text-warning"></i>
            <h5>Some Training</h5>
            <span class="bot-desc">Has figured out some basics</span>
        </div> 
        <div class="bot-card" @onclick="PlaySolid">
            <i class="fa-solid fa-battery-full fa-3x mb-3 text-success"></i>
            <h5>Highly Trained</h5>
            <span class="bot-desc">Trained not to lose, almost unbeatable</span>
        </div> 
    </div>
</div>
@code {
    private void PlayUntrained()
    {
        _navigationManager.NavigateTo("play/QLearning-new");
    }
    private void PlayCommunity()
    {
        _navigationManager.NavigateTo("play/QLearning-community");
    }
    private void PlayPartial()
    {
        _navigationManager.NavigateTo("play/QLearning-partial");
    }
    private void PlaySolid()
    {
        _navigationManager.NavigateTo("play/QLearning-solid");
    }
    private void GoBack()
    {
        _navigationManager.NavigateTo("/");
    }

}